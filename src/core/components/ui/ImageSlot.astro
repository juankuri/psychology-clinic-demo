---
import { getImage } from '../../utils/manifest';
import type { ImageSlotName } from '../../../types/manifest';

interface Props {
  /** Slot name defined in manifest.images */
  name: ImageSlotName;
  /** CSS aspect-ratio, e.g. "4 / 5" */
  ratio?: string;
  /** Cap the rendered width so images never blow out their column, e.g. "360px" */
  maxWidth?: string;
  /** Box alignment within its container when narrower than the column */
  align?: 'start' | 'center' | 'end';
  /** Extra class applied to the wrapper */
  class?: string;
  loading?: 'lazy' | 'eager';
}

const { name, ratio = '4 / 5', maxWidth, align = 'start', class: className = '', loading = 'lazy' } = Astro.props;
const img = getImage(name);
const label = img.placeholder ?? img.alt ?? 'Imagen';

const alignMap = { start: '0', center: '0 auto', end: '0 0 0 auto' } as const;
const style = [
  `aspect-ratio:${ratio}`,
  maxWidth ? `max-width:${maxWidth}` : '',
  maxWidth ? `margin:${alignMap[align]}` : '',
].filter(Boolean).join(';');
---

<div class:list={['image-slot', className]} style={style}>
  {img.active ? (
    <img src={img.src} alt={img.alt} loading={loading} decoding="async" />
  ) : (
    <div class="image-slot__placeholder" role="img" aria-label={label}>
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <circle cx="8.5" cy="8.5" r="1.5" />
        <path d="M21 15l-5-5L5 21" />
      </svg>
      <span>{label}</span>
    </div>
  )}
</div>

<style>
  .image-slot {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--color-bg-warm, var(--color-bg-alt));
  }

  .image-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-slot__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-lg);
    text-align: center;
    border: 2px dashed var(--color-border);
    border-radius: inherit;
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 12px,
        rgba(58, 53, 46, 0.02) 12px,
        rgba(58, 53, 46, 0.02) 24px
      );
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .image-slot__placeholder svg {
    opacity: 0.85;
  }
</style>
