---
import { getManifest, getWhatsAppUrl } from '../../utils/manifest';

const manifest = getManifest();
if (manifest.cta.primary.type !== 'whatsapp') return;
const href = getWhatsAppUrl(manifest);
---

<a class="fab-wa" href={href} target="_blank" rel="noopener noreferrer" aria-label="Escríbeme por WhatsApp">
  <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21 5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm0 18.15c-1.53 0-3.03-.41-4.34-1.19l-.31-.18-3.12.82.83-3.04-.2-.31a8.24 8.24 0 01-1.26-4.36c0-4.54 3.7-8.24 8.24-8.24 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 012.41 5.82c0 4.54-3.7 8.24-8.24 8.24zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z" />
  </svg>
</a>

<style>
  .fab-wa {
    position: fixed;
    right: clamp(16px, 4vw, 28px);
    bottom: clamp(16px, 4vw, 28px);
    z-index: 60;
    width: 60px;
    height: 60px;
    border-radius: var(--radius-full);
    background: var(--color-wa, #25a65b);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 12px 28px rgba(37, 166, 91, 0.4);
    animation: fab-pulse 2.6s infinite;
    transition: transform var(--transition-fast);
  }

  .fab-wa:hover {
    transform: scale(1.06);
  }

  @keyframes fab-pulse {
    0% { box-shadow: 0 0 0 0 rgba(37, 166, 91, 0.45); }
    70% { box-shadow: 0 0 0 16px rgba(37, 166, 91, 0); }
    100% { box-shadow: 0 0 0 0 rgba(37, 166, 91, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .fab-wa { animation: none; }
  }
</style>
