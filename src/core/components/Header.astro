---
import { getManifest, getNavLabel } from '../utils/manifest';

const manifest = getManifest();
const { business } = manifest;

const navIds = ['about', 'services', 'benefits', 'process', 'gallery', 'testimonials', 'faq', 'contact'] as const;
const navItems = manifest.sections
  .filter((s) => navIds.includes(s.id as (typeof navIds)[number]))
  .map((s) => ({ id: s.id, label: getNavLabel(s.id) }))
  .filter((item) => item.label);
---

<header class="header">
  <div class="container header__inner">
    <a href="#top" class="header__brand" aria-label={`${business.name} — Inicio`}>
      {business.logo && (
        <img src={business.logo} alt="" class="header__logo" width="40" height="40" aria-hidden="true" />
      )}
      <span class="header__text">
        <span class="header__name">{business.name}</span>
        {business.tagline && <span class="header__tagline">{business.tagline}</span>}
      </span>
    </a>

    {navItems.length > 0 && (
      <nav class="header__nav" aria-label="Navegación principal">
        <ul class="header__nav-list">
          {navItems.map((item) => (
            <li><a href={`#${item.id}`}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
    )}

    {navItems.length > 0 && (
      <button
        type="button"
        class="header__toggle"
        aria-expanded="false"
        aria-controls="header-mobile-nav"
        aria-label="Abrir menú"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    )}
  </div>

  {navItems.length > 0 && (
    <nav id="header-mobile-nav" class="header__mobile-nav" aria-label="Navegación móvil" hidden>
      <ul>
        {navItems.map((item) => (
          <li><a href={`#${item.id}`}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  )}
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.header__toggle');
  const mobileNav = document.querySelector<HTMLElement>('#header-mobile-nav');

  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      mobileNav.hidden = isOpen;
    });

    mobileNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        mobileNav.hidden = true;
      });
    });
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 82%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-sm);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .header__brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 1;
    min-width: 0;
  }

  .header__logo {
    height: 2.5rem;
    width: auto;
    flex-shrink: 0;
  }

  .header__text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    min-width: 0;
  }

  .header__name {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.01em;
    font-size: var(--text-lg);
    color: var(--color-text);
  }

  .header__tagline {
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .header__nav {
    display: none;
  }

  .header__nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__nav-list a {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .header__nav-list a:hover {
    color: var(--color-text);
  }

  .header__toggle {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
  }

  .header__toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text);
    border-radius: var(--radius-full);
  }

  .header__mobile-nav {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .header__mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: var(--space-sm) var(--space-md);
    display: flex;
    flex-direction: column;
  }

  .header__mobile-nav a {
    display: block;
    padding: var(--space-sm) 0;
    font-weight: 600;
    color: var(--color-text);
  }

  @media (min-width: 900px) {
    .header__nav {
      display: block;
    }

    .header__toggle {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .header__tagline {
      display: none;
    }
  }
</style>
