---
import { loadBenefits } from '../../utils/content';
import { getSectionHeading } from '../../utils/manifest';

const benefits = await loadBenefits();
if (benefits.length === 0) return;

const heading = getSectionHeading('benefits');
---

<section class="benefits section section--alt" id="benefits" aria-labelledby="benefits-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="benefits-heading">{heading}</h2>
    </div>
    <div class="grid grid--2">
      {benefits.map((benefit) => (
        <div class="benefit-card">
          <h3>{benefit.title}</h3>
          <p>{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .benefit-card {
    padding: var(--space-xl);
    text-align: center;
  }

  .benefit-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
    color: var(--color-primary);
  }

  .benefit-card p {
    color: var(--color-text-muted);
    margin-inline: auto;
  }
</style>
