---
import { loadTrust } from '../../utils/content';

const items = await loadTrust();
if (items.length === 0) return;
---

<section class="trust" aria-label="Indicadores de confianza">
  <div class="container trust__items">
    {items.map((item) => (
      <div class="trust__item">
        <span class="trust__dot" aria-hidden="true"></span>
        <span>{item.value && <strong>{item.value}</strong>} {item.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .trust {
    background: var(--color-bg-alt);
    border-block: 1px solid var(--color-border);
    padding-block: var(--space-lg);
  }

  .trust__items {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md) var(--space-2xl);
  }

  .trust__item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .trust__item strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .trust__dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-accent);
    flex: none;
  }
</style>
