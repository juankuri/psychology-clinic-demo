---
import { loadProcess } from '../../utils/content';
import { getSectionHeading, getSectionSubtitle } from '../../utils/manifest';
import WhatsAppCTA from '../ui/WhatsAppCTA.astro';

const steps = await loadProcess();
if (steps.length === 0) return;

const heading = getSectionHeading('process');
const subtitle = getSectionSubtitle('process');
---

<section class="process section section--dark" id="process" aria-labelledby="process-heading">
  <div class="container">
    <div class="section-lead process__lead">
      <span class="eyebrow">Cómo es empezar</span>
      <h2 id="process-heading">{heading}</h2>
      {subtitle && <p class="section-lead__sub">{subtitle}</p>}
    </div>

    <ol class="flow">
      {steps.map((step) => (
        <li class="flow__step">
          <div class="flow__marker">
            <span class="flow__num">{step.step}</span>
          </div>
          <h3 class="flow__title">{step.title}</h3>
          <p class="flow__desc">{step.description}</p>
        </li>
      ))}
    </ol>

    <WhatsAppCTA class="btn--wa process__cta" label="Escríbeme y resolvemos tus dudas" />
  </div>
</section>

<style>
  .process__lead .eyebrow {
    color: var(--color-accent-soft);
  }

  .process__lead .eyebrow::before {
    background: var(--color-accent);
  }

  .process__lead .section-lead__sub {
    color: color-mix(in srgb, var(--color-bg) 72%, transparent);
  }

  .flow {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 720px) {
    .flow {
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(1.5rem, 4vw, 3rem);
    }
  }

  .flow__step {
    display: flex;
    flex-direction: column;
  }

  .flow__marker {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .flow__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    flex: none;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: #fff;
    font-weight: 700;
    font-size: var(--text-lg);
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .flow__title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
  }

  .flow__desc {
    color: color-mix(in srgb, var(--color-bg) 70%, transparent);
    max-width: 34ch;
  }

  .process__cta {
    margin-top: clamp(2rem, 4vw, 3.5rem);
  }
</style>
