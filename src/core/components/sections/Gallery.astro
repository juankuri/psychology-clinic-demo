---
import { getSectionHeading } from '../../utils/manifest';
import ImageSlot from '../ui/ImageSlot.astro';
import type { ImageSlotName } from '../../../types/manifest';

const heading = getSectionHeading('gallery');
const slots: ImageSlotName[] = ['gallery-1', 'gallery-2', 'gallery-3'];
---

<section class="gallery section" id="gallery" aria-labelledby="gallery-heading">
  <div class="container">
    <div class="section-lead">
      <span class="eyebrow">El espacio</span>
      <h2 id="gallery-heading">{heading}</h2>
    </div>
    <div class="gallery__grid">
      {slots.map((slot) => (
        <ImageSlot name={slot} ratio="3 / 4" class="gallery__item" />
      ))}
    </div>
  </div>
</section>

<style>
  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
    gap: var(--space-md);
  }

  .gallery__item {
    box-shadow: var(--shadow-sm);
  }
</style>
